# Copy values into mode-specific files:
# - frontend/.env.development
# - frontend/.env.production
#
# There is no runtime localhost fallback. Both values must be set via env files.

# Local development example (Vite proxy + relative API base)
VITE_API_BASE_URL=/api/v1
VITE_BACKEND_URL=http://127.0.0.1:8000

# Production example (direct API endpoint)
# VITE_API_BASE_URL=https://your-domain.com/api/v1
# VITE_BACKEND_URL=https://your-domain.com  # optional, mainly for preview/proxy tooling
