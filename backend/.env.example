APP_NAME="Data Visualization App"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC

# Local backend URL
APP_URL=http://127.0.0.1:8000

# Local SPA URL (Vite dev server / Laragon domain)
FRONTEND_URL=http://localhost:5173

# CORS origins allowed to call Laravel API.
# Local default keeps development working.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CORS_ALLOWED_ORIGIN_PATTERNS=
CORS_SUPPORTS_CREDENTIALS=true

# Production example (required in production; do not leave localhost values):
# APP_URL=https://api.your-domain.com
# FRONTEND_URL=https://app.your-domain.com
# CORS_ALLOWED_ORIGINS=https://app.your-domain.com
# CORS_ALLOWED_ORIGIN_PATTERNS=

# Public demo project (read-only API on /api/v1/demo/project*).
# Use a dedicated project that is safe to expose.
DEMO_PROJECT_ID=

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
APP_MAINTENANCE_STORE=database

# Windows fix for `php artisan serve` with auto-reload mode.
SYSTEMROOT=C:\WINDOWS

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=dataviz
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=cookie
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=
SESSION_SECURE_COOKIE=false
SESSION_SAME_SITE=lax

# Local defaults for Sanctum SPA auth.
SANCTUM_STATEFUL_DOMAINS=localhost:5173,127.0.0.1:5173,localhost:8000,127.0.0.1:8000

# Production example:
# SANCTUM_STATEFUL_DOMAINS=app.your-domain.com,api.your-domain.com
# SESSION_DOMAIN=.your-domain.com
# SESSION_SECURE_COOKIE=true

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
CACHE_STORE=file
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"
